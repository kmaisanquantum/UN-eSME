    async function checkout() {
      if (cart.length === 0) return;

      const name = prompt("Please enter your name:");
      if (!name) return;
      const phone = prompt("Please enter your phone number:");
      if (!phone) return;

      const vendorIds = [...new Set(cart.map(item => item.vendor_id))];

      try {
        for (const vId of vendorIds) {
          const vendorItems = cart.filter(item => item.vendor_id === vId);
          const total = vendorItems.reduce((sum, item) => sum + (item.price * item.quantity), 0);

          await fetch('/api/orders', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              vendor_id: vId,
              customer_name: name,
              customer_phone: phone,
              items: vendorItems,
              total_price: total
            })
          });
        }

        alert('Order placed successfully! Vendors will contact you via WhatsApp.');
        cart = [];
        saveCart();
        updateCartUI();
        toggleCart();
      } catch (err) {
        alert('Failed to place order: ' + err.message);
      }
    }
